---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}

const {
  eyebrow,
  title,
  description,
  align = "left",
} = Astro.props;
---

<div class:list={[
  "section-heading",
  `section-heading--${align}`,
]}>
  {eyebrow && <p class="section-heading__eyebrow">{eyebrow}</p>}
  <h2 class="section-heading__title">{title}</h2>
  {description && <p class="section-heading__description">{description}</p>}
</div>
