---
interface Props {
  columns?: 2 | 3 | 4;
  gap?: "sm" | "md" | "lg";
  class?: string;
}

const {
  columns = 3,
  gap = "md",
  class: className = "",
} = Astro.props;

const classes = [
  "grid",
  `grid--${columns}`,
  `grid--gap-${gap}`,
  className,
].filter(Boolean).join(" ");
---

<div class={classes}>
  <slot />
</div>
