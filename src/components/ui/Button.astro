---
type Variant = "primary" | "secondary" | "outline" | "ghost";
type Size = "sm" | "md" | "lg";

interface Props {
  href?: string;
  type?: "button" | "submit" | "reset";
  variant?: Variant;
  size?: Size;
  fullWidth?: boolean;
  class?: string;
}

const {
  href,
  type = "button",
  variant = "primary",
  size = "md",
  fullWidth = false,
  class: className = "",
} = Astro.props;

const classes = [
  "btn",
  `btn--${variant}`,
  `btn--${size}`,
  fullWidth ? "btn--full" : "",
  className,
].filter(Boolean).join(" ");
---

{href ? (
  <a href={href} class={classes}>
    <slot />
  </a>
) : (
  <button type={type} class={classes}>
    <slot />
  </button>
)}
