---
interface Props {
  as?: keyof HTMLElementTagNameMap;
  class?: string;
}

const {
  as: Tag = "div",
  class: className = "",
} = Astro.props;
---

<Tag class={`container ${className}`}>
  <slot />
</Tag>

<style>
  .container {
    width: 100%;
    max-width: var(--container-width);
    margin-inline: auto;
    padding-inline: var(--space-4);
  }

  @media (min-width: 768px) {
    .container {
      padding-inline: var(--space-6);
    }
  }
</style>