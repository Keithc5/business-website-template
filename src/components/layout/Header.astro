---
import { business } from '@config/activeSite';
import { stripBasePath, withBasePath } from '@utils/site-url';

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Services', href: '/services' },
  { label: 'Gallery', href: '/gallery' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = stripBasePath(Astro.url.pathname);
const normalisePath = (path: string) =>
  path !== "/" ? path.replace(/\/$/, "") : path;

const currentPathname = normalisePath(currentPath);
---

<header class="site-header">
  <div class="container header-inner">
    <a href={withBasePath("/")} class="logo" aria-label={`${business.name} home`}>
      {business.name}
    </a>

    <nav class="nav nav--desktop" aria-label="Main navigation">
      {navItems.map((item) => (
        <a
          href={withBasePath(item.href)}
          aria-current={currentPathname === item.href ? "page" : undefined}
          class:list={[
            'nav-link',
            currentPathname === item.href && 'active',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <details class="mobile-nav">
      <summary class="mobile-nav__summary">Menu</summary>
      <nav class="mobile-nav__panel" aria-label="Mobile navigation">
        {navItems.map((item) => (
          <a
            href={withBasePath(item.href)}
            aria-current={currentPathname === item.href ? "page" : undefined}
            class:list={[
              'nav-link',
              'mobile-nav__link',
              currentPathname === item.href && 'active',
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>
    </details>
  </div>
</header>
