# Select which site config to use.
# Accepted values: generic, glensound-brother-in-law, glensound-dad, balloons4u
# Optional; defaults to generic.
PUBLIC_SITE_ID=generic

# Select deployment URL behavior.
# Accepted values: github-pages or blank.
# Optional; use github-pages only for this repository's project-site deployment.
PUBLIC_DEPLOY_TARGET=

# Optional until Cloudinary image delivery is enabled.
# Set to the public cloud name only; never add a Cloudinary API secret here.
PUBLIC_CLOUDINARY_CLOUD_NAME=
